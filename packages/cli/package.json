{
  "name": "clankybuddy",
  "version": "0.1.0",
  "description": "Terminal companion for ClankyBuddy, anonymous global chat for devs venting about their AI.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/glendonC/clankybuddy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glendonC/clankybuddy.git"
  },
  "bugs": {
    "url": "https://github.com/glendonC/clankybuddy/issues"
  },
  "keywords": [
    "chat",
    "terminal",
    "tui",
    "ink",
    "claude",
    "anonymous"
  ],
  "bin": {
    "clankybuddy": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "ink": "^5.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
